# Server  (5050 avoids macOS AirPlay Receiver, which occupies port 5000)
PORT=5050
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (local MongoDB). For Atlas, paste your SRV string here instead.
MONGO_URI=mongodb://127.0.0.1:27017/ai_hrms

# Auth
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# AI provider (free, OpenAI-compatible). Default: Groq.
# Get a free key at https://console.groq.com/keys
AI_PROVIDER=groq
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile

# If AI_API_KEY is empty, the server falls back to a local heuristic mock so
# the app still runs and demos without any external key.
